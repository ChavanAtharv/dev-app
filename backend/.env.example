# ============================================
# Nexus CI/CD Dashboard — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# PostgreSQL connection string
# Local:    postgresql://user:password@localhost:5432/nexus_cicd
# Render:   Use the "Internal Database URL" from your Render PostgreSQL dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_cicd"

# Server port (Render uses 10000 by default)
PORT=10000
